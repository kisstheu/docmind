# --- JetBrains 官方推荐排除的私人工作区配置 ---
.idea/**/workspace.xml
.idea/**/tasks.xml
.idea/**/usage.statistics.xml
.idea/**/dictionaries
.idea/**/shelf

# --- 环境与编辑器 ---
.venv/
.vscode/
__pycache__/
*.py[cod]

# --- NAS 与操作系统垃圾 ---
.SynologyWorkingDirectory/
desktop.ini
$RECYCLE.BIN/
Thumbs.db

# --- 运行时生成目录 ---
.docmind_trash/

# --- 项目运行缓存与日志 ---
cache/
*.log
*.npz
logs/

# --- 自动生成的伴生文件 ---
test_notes/*.ocr.txt

# --- 敏感数据 ---
test_notes/
/.idea/inspectionProfiles/Project_Default.xml
/.idea/misc.xml
/cache/demo_notes_public/file_change_log.db
/cache/kisstheu/file_change_log.db

# --- 运行期数据库 ---
file_change_log.db
*.db

pack_docmind.py
/tests/

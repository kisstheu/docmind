# DocMind VS Code 调试环境示例
# 用法：复制为 .env 后按需修改；launch.json 会自动读取该文件。

# 必填：远程模型 API Key
OPENAI_API_KEY=your_api_key_here

# 可选：默认资料目录；若 launch.json 里传了 --notes-dir，则这里会被覆盖
DOCMIND_NOTES_DIR=examples/demo_notes_public

# 可选：问句追踪调试
DOCMIND_DEBUG_SAVE_QUESTIONS=0
DOCMIND_DEBUG_SAVE_DIR=logs/debug_questions

# 可选：命中日志输出上限
DOCMIND_MATCH_LOG_LIMIT=60

# 可选：闲聊 / 越界问题本地 LLM 开关
DOCMIND_SMALLTALK_LOCAL_LLM=1
DOCMIND_OUT_OF_SCOPE_LOCAL_LLM=1
DOCMIND_SMALLTALK_REWRITE_TIMEOUT=2.5

# 可选：回复风格
DOCMIND_EMOJI_ENABLED=1
DOCMIND_EMOJI_LEVEL=1

# 可选：日志输出
DOCMIND_LOG_FILE=logs/docmind_sys.log
DOCMIND_LOG_BACKUP_COUNT=8
DOCMIND_LOG_ROTATE_WHEN=midnight
DOCMIND_LOG_ROTATE_INTERVAL=1
DOCMIND_LOG_ROTATE_UTC=0

# 可选：索引 / 标签提取
DOCMIND_INDEX_OLLAMA_TIMEOUT_SEC=8
DOCMIND_INDEX_OLLAMA_RETRIES=0
DOCMIND_INDEX_TAG_MODE=ollama

# 可选：较重 PDF 处理开关
DOCMIND_ENABLE_HEAVY_PDF=0

# 可选：嵌入模型加载策略
# 0=允许首次联网下载并写入本地缓存，1=仅使用本地缓存
DOCMIND_EMBEDDING_LOCAL_ONLY=0

# 一般无需修改：离线与代理默认值
http_proxy=http://127.0.0.1:7897
https_proxy=http://127.0.0.1:7897
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
NO_PROXY=localhost,127.0.0.1
